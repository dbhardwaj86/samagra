# TeachingOS configuration template.
# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# --- Source workspace roots (override only if your paths differ) ---
TEACHINGOS_GPT_BOX=C:\SandBox\gpt_box
TEACHINGOS_CLAUDE_BOX=C:\SandBox\claude_box

# --- Per-source overrides (optional; derived from the boxes above by default) ---
# TEACHINGOS_QX_ROOT=C:\SandBox\gpt_box\gpt-extract-ques
# TEACHINGOS_TEXTBOOK_ROOT=C:\SandBox\gpt_box\physics-textbook
# TEACHINGOS_BOOKLETS_ROOT=C:\SandBox\claude_box\claude-booklet-proofer
# TEACHINGOS_INSP_ROOT=C:\SandBox\claude_box\claude-INSP-extract
# TEACHINGOS_SIMS_ROOT=C:\SandBox\claude_box\pratyaksh-May-deploy

# --- Online target (QX HuggingFace Space; currently private) ---
TEACHINGOS_QUESTIONDB_URL=https://dbhardwaj86-questiondb.hf.space

# --- Portal ---
TEACHINGOS_HOST=127.0.0.1
TEACHINGOS_PORT=8799

# --- Notifications (Phase D) ---
# Telegram via Hermes
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email (gmail app password, not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dbhardwaj86@gmail.com
SMTP_PASS=
NOTIFY_EMAIL_TO=dbhardwaj86@gmail.com

# --- Google Docs export (Phase C) ---
# Path to OAuth client secret JSON; token cache is created next to it.
GOOGLE_OAUTH_CLIENT=secrets\google_client_secret.json
GOOGLE_DOCS_FOLDER_ID=
