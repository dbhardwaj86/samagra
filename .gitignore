# --- secrets & local config (PUBLIC REPO: never commit) ---
.env
config.local.py
*.secret
secrets/
*token*.json
credentials*.json
client_secret*.json

# --- generated data (content/state stay local, never in git) ---
samagra.db
concept_graph.db
*.db
state/
build/
dist/
exports/
lectures_out/
.serve-logs/
# Phase 3 bridge: outbox prompt files are runtime artifacts (per-assignment,
# carry proposal content) — keep the tracked .gitkeep, ignore generated prompts.
board/*/outbox/*.md

# --- claude local settings ---
.claude/settings.local.json

# --- python ---
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.pytmp/
.pytest_tmp/
.pytest_tmp_audit/
.pytest-tmp*/
.mypy_cache/
*.egg-info/
.coverage

# --- codex review run logs (keep reports + runbook, drop raw run logs) ---
docs/codex-reviews/*.log

# --- frontend (node / vite) ---
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
*.tsbuildinfo

# local design reference (extracted handoff zip — read-only, not source)
.design-ref/
Web OS GUI design.zip

# --- cloudflare tunnel (Phase B): commit only the non-secret config.yml ---
# W1.5: ** so a tunnel-cred JSON copied beside the committed config at ANY depth
# (e.g. deploy/cloudflared/<UUID>.json) is ignored, not just root-level cloudflared/.
*.pem
cloudflared/*.json
**/cloudflared/*.json
mcd-cloud.json
published/
